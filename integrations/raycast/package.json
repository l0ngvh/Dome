{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "dome",
  "title": "Dome",
  "description": "Restore minimized Dome windows from Raycast.",
  "icon": "command-icon.png",
  "author": "dome",
  "license": "MIT",
  "commands": [
    {
      "name": "list-minimized-windows",
      "title": "List Minimized Windows",
      "subtitle": "Dome",
      "description": "List and restore minimized Dome windows.",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.83.0",
    "@raycast/utils": "^1.17.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.11",
    "@types/node": "^20.11.20",
    "@types/react": "^19.0.10",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "typescript": "^5.3.3"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  }
}
